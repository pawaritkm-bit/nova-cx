{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/health-ping",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/process-ai",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/process-notifications",
      "schedule": "*/5 * * * *"
    }
  ],
  "functions": {
    "app/api/**/route.ts": {
      "maxDuration": 60
    }
  }
}
