# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === LINE OA / LIFF (2 บัญชี) ===
# OA "Care" — ประเมินสำนักงานบัญชี (A) + ประเมินพนักงานทีมบัญชี (B)
LINE_CARE_CHANNEL_ID=
LINE_CARE_CHANNEL_SECRET=
LINE_CARE_CHANNEL_ACCESS_TOKEN=
LINE_CARE_LIFF_ID=

# OA "Sale" — ประเมินเซล ขายได้ (C) + ขายไม่ได้ (D)
LINE_SALE_CHANNEL_ID=
LINE_SALE_CHANNEL_SECRET=
LINE_SALE_CHANNEL_ACCESS_TOKEN=
LINE_SALE_LIFF_ID=

# group id ของ "กลุ่ม LINE สำนักงาน" (แบบประเมิน A ส่งเข้ากลุ่มนี้)
# fallback ระดับ env — เฟสแรกยังไม่เก็บ group id ต่อลูกค้าใน DB
LINE_CARE_OFFICE_GROUP_ID=
# tenant override สำหรับ LINE webhook (multi-tenant) — เว้นว่าง = ใช้ tenant แรกในระบบ
LINE_TENANT_ID=

# === AI ===
OPENAI_API_KEY=
AI_PROVIDER=openai
# โมเดลที่ใช้สรุป/จัดหมวด (รุ่น mini) — เว้นว่าง = gpt-4o-mini
OPENAI_MODEL=

# === Security ===
# กุญแจเข้ารหัส credential (ตั้งครั้งเดียว ห้ามเปลี่ยนภายหลัง)
CREDENTIAL_ENC_KEY=

# === Cron / Worker ===
# secret สำหรับ Vercel Cron (ส่งเป็น Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=

# === Integration: NOVA Sales → NOVA-CX ===
# secret ยืนยันตัวตนระหว่างระบบ — NOVA Sales ส่งมาใน header `x-api-key`
# เมื่อเปิดลูกค้า/ปิดดีล (Won/Lost) เพื่อ upsert ลูกค้า/ดีล + enqueue แบบประเมินเซล
# ถ้าเว้นว่าง endpoint /api/integrations/nova-sales/* จะตอบ 503 (ปิดไว้)
NOVA_SALES_API_KEY=
# tenant ที่ผูกกับ API key ด้านบน (allowlist) — integration รับเฉพาะ payload.tenant_id นี้
# กัน key เดียวเขียนข้าม tenant; เว้นว่าง = ไม่บังคับ (dev) แต่ควรตั้งใน prod
NOVA_SALES_TENANT_ID=

# === Test (optional) ===
# ใช้เฉพาะรัน RLS/permission test กับ Postgres จริง (เว้นว่าง = ข้าม test กลุ่มนี้)
DATABASE_URL=

# === App base URL (สร้างลิงก์แบบประเมิน survey_url ฝั่งเซล) ===
NEXT_PUBLIC_APP_URL=
